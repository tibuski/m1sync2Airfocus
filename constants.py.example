# =============================================================================
# JIRA Configuration
# =============================================================================

JIRA_REST_URL = "https://your-jira-instance.com/rest/api/latest"
JIRA_PROJECT_KEY = "YOUR_PROJECT_KEY"
JIRA_PAT = "your-jira-personal-access-token-here"
# Optional: override with env var JIRA_PAT

# =============================================================================
# Azure DevOps Configuration
# =============================================================================

AZURE_DEVOPS_URL = "https://dev.azure.com/your-org/your-project"
AZURE_DEVOPS_WORK_ITEM_TYPE = "Epic"

# Optional: specify tenant ID to skip tenant selection
AZURE_TENANT_ID = ""

# Optional overrides

# Azure DevOps AAD resource/audience. This GUID is static for Azure DevOps and normally should not be changed.
AZURE_DEVOPS_RESOURCE = "499b84ac-1321-427f-aa17-267ca6975798"

AZURE_CLI_PYTHON_EXE = r"C:\Program Files (x86)\Microsoft SDKs\Azure\CLI2\python.exe"
AZURE_CLI_BAT_PATH = r"C:\Program Files (x86)\Microsoft SDKs\Azure\CLI2\Scripts\az.bat"

# =============================================================================
# Airfocus Configuration
# =============================================================================

AIRFOCUS_REST_URL = "https://app.airfocus.com/api"
AIRFOCUS_WORKSPACE_ID = "your-workspace-id-here"
AIRFOCUS_API_KEY = "your-airfocus-api-key-here"
# Optional: override with env vars AIRFOCUS_API_KEY / AIRFOCUS_WORKSPACE_ID

# =============================================================================
# Sync Options
# =============================================================================

JIRA_TO_AIRFOCUS_STATUS_MAPPING = {
    "Draft": ["To Do", "Open"],
    "In Progress": ["In Progress", "IN REFINEMENT"],
    "Done": ["Done", "Cancelled"],
    "On Hold": ["On hold"]
}

AZURE_DEVOPS_TO_AIRFOCUS_STATUS_MAPPING = {
    "Draft": ["New"],
    "In Progress": ["Active"],
    "Done": ["Resolved", "Closed", "Removed"],
    "On Hold": ["On hold"],
}

TEAM_FIELD = {"YOUR_TEAM_FIELD_NAME": ["YOUR_TEAM_VALUE"]}

DATE_RANGE_FIELD = "DATE_RANGE_FIELD_NAME"

# =============================================================================
# General Settings
# =============================================================================

DATA_DIR = "data"
LOG_FILE_PATH = "data/jira2airfocus.log"
LOGGING_LEVEL = "WARNING"
SNAPSHOT_FILES_TO_KEEP = 3
SSL_VERIFY = False
